# ──────────────────────────────────────────────────────────────────────────────
# .env.example — copy this to .env and fill in your real values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── JWT ───────────────────────────────────────────────────────────────────────
# Secret used to sign and verify user session tokens.
# Use a long, randomly generated string (32+ characters).
JWT_SECRET=replace_with_a_strong_random_secret

# ── Bot panel limits ──────────────────────────────────────────────────────────
# Maximum number of Minecraft bot projects allowed per user account.
MAX_PROJECTS_PER_USER=3

# ── Web server ────────────────────────────────────────────────────────────────
PORT=4000

# ── Security ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins for CORS.
# In production, replace with your actual web panel domains.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:4000,https://panel.example.com

# ── Telegram ─────────────────────────────────────────────────────────────────
# Token from @BotFather. Do NOT share this.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Admin account ─────────────────────────────────────────────────────────────
# Username and password for the auto-created admin account on first startup.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_a_strong_password

# ── API URLs ──────────────────────────────────────────────────────────────────
# URL the Telegram bot uses to reach the web server.
# In local development: http://localhost:4000
# In production: your public domain, e.g. https://afk.example.com
BOT_API_URL=http://localhost:4000

# Public URL served to frontend clients (used for Telegram Web App buttons).
# Must be HTTPS for Telegram Web Apps to function.
EXPO_PUBLIC_API_URL=https://your-public-domain.com

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Full connection string from MongoDB Atlas (or your self-hosted instance).
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<appName>

# ── SQLite (Prisma) ───────────────────────────────────────────────────────────
# Path to the local SQLite database file used by the Telegram bot for server
# and group settings. Relative to the project root.
DATABASE_URL=file:./prisma/servers.db

# ── Web App ───────────────────────────────────────────────────────────────────
# The URL shown to users in Telegram bot messages and inline buttons.
WEB_APP_URL=https://your-public-domain.com
