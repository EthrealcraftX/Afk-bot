JWT_SECRET=your_very_strong_key_here 
# This is the secret key used for signing JWT tokens. Make sure to use a strong, unique key and keep it secure.
MAX_PROJECTS_PER_USER=3
# This is the maximum number of projects a user can create. Adjust as needed.
PORT=3000
# The port on which the server will run. Change if 3000 is already in use.
TELEGRAM_BOT_TOKEN=123456789:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefg 
# Replace with your actual Telegram bot token. Keep this secret!
ADMIN_USERNAME=admin
 # The username for the admin account. Change for better security.
ADMIN_PASSWORD=admin 
# The password for the admin account. Change this to a strong password!
EXPO_PUBLIC_API_URL=https://you.domain.com 
# The public URL for your API. Change to your actual domain.
MONGODB_URI=mongodb+srv://username:password@mcafk.qmhhkfq.mongodb.net/?appName=mcafk 
# Replace with your actual MongoDB connection string. Keep this secret!