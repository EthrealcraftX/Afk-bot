generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Server {
  id               String   @id @default(uuid())
  host             String
  port             Int
  edition          String   // "java" | "bedrock"

  // Original input — never throw this away
  inputAddress     String?  // e.g. "bedwars-rLDO" or "play.example.com"
  originalType     String?  // "aternos_domain" | "aternos_url" | "aternos_name" | "domain" | "ipv4"

  version          String?
  motd             String?
  players          Int      @default(0)
  maxPlayers       Int      @default(0)
  status           String   // "online" | "offline"
  latency          Int      @default(0)
  category         String   @default("Unknown")
  
  firstSeen        DateTime @default(now())
  lastSeen         DateTime @default(now())
  lastChecked      DateTime @default(now())
  
  timesDetected    Int      @default(1)
  timesRecommended Int      @default(0)

  @@unique([host, port, edition])
}

model GroupSettings {
  chatId                 String   @id
  autoReplyEnabled       Boolean  @default(true)
  recommendationsEnabled Boolean  @default(true)
  language               String   @default("uz")
  cooldownMs             Int      @default(60000)
  recommendationLimit    Int      @default(3)
}
